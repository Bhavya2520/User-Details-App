# Copy this file to .env and set your own values.
# Do NOT commit the .env file if it contains real secrets.

# Postgres container settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=example
POSTGRES_DB=usersdb

# Postgres client settings for the backend
PGHOST=db
PGUSER=postgres
PGPASSWORD=example
PGDATABASE=usersdb
PGPORT=5432

# Node environment
NODE_ENV=production
